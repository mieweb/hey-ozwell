.env
*.DS_Store
.DS_Store
.playwright-mcp/

# Node
prod/js/node_modules/
prod/js/dist/
prod/js/build/

# Extracted training data (data.zip itself is tracked via LFS)
model/data/positive/
model/data/negative/
model/data/*.npy
model/data/*.json

# Loose wavs (use LFS if intentionally committing)
*.wav
!model/data/data.zip

# Python caches
__pycache__/
*.pyc

# Eval harness scratch (downloaded models + generated figures — regenerate, don't commit)
model/eval/pretrained/
model/eval/figures/
# Large regenerable training artifacts (do not commit)
model/checkpoints/
model/heybuddy/precalculated/
model/heybuddy/pretrained/
model/logs/*.log
prod/js/models/*.amanda-bak

# Speaker-verification WASM binaries (large build artifacts — regenerate via the
# build runbook in prod/js/docs/speaker-verification-spike.md, or scp from the build box)
prod/js/sv-wasm/*.wasm
prod/js/sv-wasm/*.data
prod/js/sv-runtime/*.wasm
prod/js/sv-runtime/*.data
